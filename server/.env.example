# Supabase project URL used by the server.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Server-only credential. Never copy this value into the iOS client.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# DashScope credential and optional multimodal model override.
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY
DASHSCOPE_MODEL=qwen-omni-turbo-0119
