	<string>$(MIAOJI_API_BASE_URL)</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>PRIVACY_POLICY_URL</key>
	<string>https://github.com/KapiYue/miaoji/blob/main/docs/privacy-policy.md</string>
