	<string>$(SUPABASE_PUBLISHABLE_KEY)</string>
	<key>SUPABASE_URL</key>
	<string>$(SUPABASE_URL)</string>
	<key>SUPPORT_URL</key>
	<string>https://github.com/KapiYue/miaoji/blob/main/docs/support.md</string>
	<key>TERMS_OF_SERVICE_URL</key>
	<string>https://github.com/KapiYue/miaoji/blob/main/docs/terms-of-service.md</string>
